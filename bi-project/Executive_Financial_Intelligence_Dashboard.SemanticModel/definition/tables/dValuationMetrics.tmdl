				DATATABLE (
				    "ValuationMetric", STRING, 
				    "SortOrder", INTEGER,
				    {
				        {"Present Value of Cash Flows", 1},
				        {"Terminal Value", 2},
				        {"Implied Enterprise Value", 3},
				        {"Implied Share Price", 4}
				    }
				)
				
				
				```

	annotation PBI_Id = 16bf42ce2ed74b749be74c496c219ba6

