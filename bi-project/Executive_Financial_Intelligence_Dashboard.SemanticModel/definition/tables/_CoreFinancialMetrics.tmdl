	measure 'Tax Rate' = ```
			
			-- 1. Calculate Pre-Tax Income by filtering your unpivoted table
			VAR PreTaxIncome = 
			    CALCULATE(
			        SUM('fIncomeStatementForecast'[Amount]), 
			        'dAccount'[AccountHead] = "incomeBeforeTax"
			    )
			
			-- 2. Calculate Tax Expense by filtering your unpivoted table
			VAR TaxExpense = 
			    CALCULATE(
			        SUM('fIncomeStatementForecast'[Amount]), 
			        'dAccount'[AccountHead] = "incomeTaxExpense"
			    )
			
			-- 3. Return a blank if there is no profit, otherwise safely divide
			RETURN
			    IF(
			        PreTaxIncome <= 0, 
			        BLANK(), 
			        DIVIDE(TaxExpense, PreTaxIncome, 0)
			    )
			
			
			```
		formatString: 0.00%;-0.00%;0.00%
