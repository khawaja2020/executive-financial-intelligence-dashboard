	measure Ratio_TrailingPE = ```
			
			-- 1. Grab the current stock price from your market data table
			VAR StockPrice = MAX('fMarketData'[Price])
			
			-- 2. Extract the EPS amount by filtering the unpivoted income statement table
			VAR EarningsPerShare = 
			    CALCULATE(
			        SUM('fIncomeStatementForecast'[Amount]), 
			        'dAccount'[AccountHead] = "EPS"
			    )
			
			-- 3. Safely divide stock price by EPS to compute the trailing P/E ratio
			RETURN
			    DIVIDE(StockPrice, EarningsPerShare, 0)
			
			```
