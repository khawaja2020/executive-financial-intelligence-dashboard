table _CoreFinancialMetrics
	lineageTag: d69639b0-d8b4-4640-bdc1-ab1210f39918

	measure Unified_Financial_Metric = ```
			
			VAR SelectedScenario = SELECTEDVALUE('dScenario'[ScenarioName], "Actual")
			VAR SelectedVersion = SELECTEDVALUE('dVersion'[VersionName], "Base Case")
			VAR CurrentStatement = SELECTEDVALUE('dAccount'[FinancialStatement])
			VAR CurrentAccountHead = SELECTEDVALUE('dAccount'[AccountHead])
			
			-- Only Cash Flow needs _CF suffix removed
			VAR FactAccountHead = 
			    IF(
			        CurrentStatement = "Cash Flow",
			        SWITCH(
			            CurrentAccountHead,
			            "netIncome_CF", "netIncome",
			            "depreciationAndAmortization_CF", "depreciationAndAmortization",
			            "accountsPayables_CF", "accountsPayables",
			            CurrentAccountHead
			        ),
			        CurrentAccountHead
			    )
			
			-------------------------------------------------------------------------
			-- A. INCOME STATEMENT
			-------------------------------------------------------------------------
			VAR IS_Actual = 
			    CALCULATE(
			        SUM('fIncomeStatementForecast'[Amount]), 
			        VALUE('fIncomeStatementForecast'[IsForecast]) = 0,
			        'fIncomeStatementForecast'[AccountHead] = FactAccountHead
			    )
			
			VAR IS_Forecast = 
			    CALCULATE(
			        SUM('fIncomeStatementForecast'[Amount]), 
			        VALUE('fIncomeStatementForecast'[IsForecast]) = 1,
			        'fIncomeStatementForecast'[AccountHead] = FactAccountHead
			    )
			
			-- Map AccountHead to Department for budget aggregation
			VAR BudgetFilterDepartment = 
			    SWITCH(
			        CurrentAccountHead,
			        "researchAndDevelopmentExpenses", "R&D",
			        "sellingAndMarketingExpenses", BLANK(),
			        "sellingGeneralAndAdministrativeExpenses", "Sales",
			        "operatingExpenses", "Operations",
			        BLANK()
			    )
			
			VAR IS_Budget = 
			    IF(
			        ISBLANK(BudgetFilterDepartment),
			        BLANK(),
			        CALCULATE(
			            SUM('fInternalBudgets'[BudgetAmount]), 
			            'fInternalBudgets'[ForecastScenario] = SelectedVersion,
			            'fInternalBudgets'[Department] = BudgetFilterDepartment
			            )
			    )
			
			VAR IS_Final = 
			    SWITCH(
			        SelectedScenario,
			        "Actual", IS_Actual,
			        "Forecast", IS_Forecast,
			        "Budget", IS_Budget,
			        BLANK()
			    )
			
			-------------------------------------------------------------------------
			-- B. BALANCE SHEET
			-------------------------------------------------------------------------
			VAR BS_Final = 
			    IF(
			        SelectedScenario = "Actual", 
			        CALCULATE(
			            SUM('fBalanceSheet'[Amount]),
			            'fBalanceSheet'[AccountHead] = FactAccountHead
			        ), 
			        BLANK()
			    )
			
			-------------------------------------------------------------------------
			-- C. CASH FLOW
			-------------------------------------------------------------------------
			VAR CF_Final = 
			    IF(
			        SelectedScenario = "Actual", 
			        CALCULATE(
			            SUM('fCashFlow'[Amount]),
			            'fCashFlow'[AccountHead] = FactAccountHead
			        ), 
			        BLANK()
			    )
			
			-------------------------------------------------------------------------
			-- D. RETURN
			-------------------------------------------------------------------------
			RETURN
			    SWITCH(
			        CurrentStatement,
			        "Income Statement", IS_Final,
			        "Balance Sheet", BS_Final,
			        "Cash Flow", CF_Final,
			        BLANK()
			    )
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 4d27b913-a723-4014-abf8-083b7beed5cf

	measure Ratio_Current = ```
			
			-- 1. Calculate Total Current Assets by filtering the unpivoted table
			VAR CurrentAssets = 
			    CALCULATE(
			        SUM('fBalanceSheet'[Amount]), 
			        'dAccount'[AccountHead] = "totalCurrentAssets"
			    )
			
			-- 2. Calculate Total Current Liabilities by filtering the unpivoted table
			VAR CurrentLiabilities = 
			    CALCULATE(
			        SUM('fBalanceSheet'[Amount]), 
			        'dAccount'[AccountHead] = "totalCurrentLiabilities"
			    )
			
			-- 3. Safely divide the two values to avoid divide-by-zero errors
			RETURN
			    DIVIDE(CurrentAssets, CurrentLiabilities, 0)
			
			
			```
		lineageTag: b10e0f1e-83d0-4847-b6f8-b30b9585b7dd

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Ratio_Quick = ```
			
			-- 1. Calculate Total Current Assets
			VAR CurrentAssets = 
			    CALCULATE(
			        SUM('fBalanceSheet'[Amount]), 
			        'dAccount'[AccountHead] = "totalCurrentAssets"
			    )
			
			-- 2. Calculate Inventory to exclude
			VAR Inventory = 
			    CALCULATE(
			        SUM('fBalanceSheet'[Amount]), 
			        'dAccount'[AccountHead] = "inventory"
			    )
			
			-- 3. Calculate Total Current Liabilities
			VAR CurrentLiabilities = 
			    CALCULATE(
			        SUM('fBalanceSheet'[Amount]), 
			        'dAccount'[AccountHead] = "totalCurrentLiabilities"
			    )
			
			-- 4. Subtract inventory and safely divide
			VAR QuickAssets = CurrentAssets - Inventory
			RETURN
			    DIVIDE(QuickAssets, CurrentLiabilities, 0)
			
			```
		lineageTag: c124ed1a-a4b6-4a81-9f2c-a790a8a58fec

