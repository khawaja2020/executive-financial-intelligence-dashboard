	measure WACC_Engine = ```
			
			-- 1. Identify your last historical year to isolate current balance sheet metrics
			VAR LastActualYear = 
			    CALCULATE(
			        MAX('dCalendar'[Year]), 
			        'fIncomeStatementForecast'[IsForecast] = 0, 
			        REMOVEFILTERS()
			    )
			
			-- 2. Calculate Cost of Equity (CAPM)
			VAR CostOfEquity = 
			    MAX('dMacroAssumptions'[RiskFreeRate]) + 
			    (MAX('dMacroAssumptions'[IndustryBeta]) * MAX('dMacroAssumptions'[MarketRiskPremium]))
			
			-- 3. Extract Interest Expense and Total Debt for the current calculation period
			VAR InterestExpense = 
			    CALCULATE(
			        SUM('fIncomeStatementForecast'[Amount]), 
			        'dAccount'[AccountHead] = "Interest Expense",
			        'dCalendar'[Year] = LastActualYear
			    )
			
			VAR TotalDebt = 
			    CALCULATE(
			        SUM('fBalanceSheet'[Amount]), 
			        'dAccount'[AccountHead] = "totalDebt",
			        'dCalendar'[Year] = LastActualYear
			    )
			
			-- 4. Calculate After-Tax Cost of Debt
			VAR PreTaxCostOfDebt = DIVIDE(InterestExpense, TotalDebt, 0)
			VAR CostOfDebt = PreTaxCostOfDebt * (1 - MAX('dMacroAssumptions'[CorporateTaxRate]))
			
			-- 5. Calculate Capital Structure Weights
			VAR MarketCapValue = MAX('MarketCap'[MarketCap])
			VAR TotalCapital = MarketCapValue + TotalDebt
			VAR EquityWeight = DIVIDE(MarketCapValue, TotalCapital, 0)
			
			-- 6. Execute WACC
			 RETURN 
			    (CostOfEquity * EquityWeight) + (CostOfDebt * (1 - EquityWeight))
			
			```
		formatString: #,0.00%;-#,0.00%;#,0.00%
		lineageTag: 9e562bd5-e206-48d3-8adf-88c2efe13853

	measure Master_Discounted_FCF = ```
			
			-- 1. Scan whichever calendar or forecast year column is actively used in your visual rows
			VAR CurrentYear = 
			    COALESCE(
			        SELECTEDVALUE('dCalendar'[Year]), 
			        SELECTEDVALUE('fIncomeStatementForecast'[Year])
			    )
			
			-- 2. Force the calculation to lock onto 2025 as the absolute baseline anchor
			VAR YearIndex = CurrentYear - 2025
			VAR WACC = [WACC_Adjustment Value] 
			VAR FCF = [Dynamic_Free_Cash_Flow]
			
			-- 3. Execute the exact single-year math row-by-row
			RETURN
			    IF(
			        YearIndex > 0 && FCF > 0,
			        DIVIDE(FCF, POWER(1 + WACC, YearIndex), 0),
			        BLANK()
			    )
			
			```
		formatString: #,0
		lineageTag: 63827a8f-2efc-4a01-8a98-881f57adfb6b

		annotation PBI_FormatHint = {"isDecimal":true}

	measure Project_ROI_Annual = ```
			
			VAR CurrentYearRow = COALESCE(SELECTEDVALUE('dCalendar'[Year]), SELECTEDVALUE('fIncomeStatementForecast'[Year]))
			
			-- 1. Build a clean, isolated running list of years from 2021 up to the current row
			VAR TimelineHorizon = 
			    FILTER(
			        ALLSELECTED('dCalendar'[Year]),
			        'dCalendar'[Year] >= 2021 && 'dCalendar'[Year] <= CurrentYearRow
			    )
			
			-- 2. Extract historical base parameters directly from the fact tables to establish conversion factor
			VAR HistNetIncome = CALCULATE(SUM('fIncomeStatementForecast'[Amount]), 'fIncomeStatementForecast'[IsForecast] = 0, 'fIncomeStatementForecast'[AccountHead] = "Net Income", REMOVEFILTERS())
			VAR HistFCF = CALCULATE(SUM('fCashFlow'[Amount]), 'fCashFlow'[AccountHead] = "freeCashFlow", REMOVEFILTERS())
			VAR CashConversionRate = DIVIDE(HistFCF, HistNetIncome, 0)
			
			VAR HistCapEx = CALCULATE(ABS(SUM('fCashFlow'[Amount])), 'fCashFlow'[AccountHead] = "capitalExpenditure", REMOVEFILTERS())
			VAR CapExIntensityRate = DIVIDE(HistCapEx, HistNetIncome, 0)
			
			-- 3. Run a pure, unhindered loop in memory to build the cumulative cash and capex pools
			VAR CumulativeCashInflows = 
			    SUMX(
			        TimelineHorizon,
			        VAR LoopYear = 'dCalendar'[Year]
			        VAR ActualFCF = CALCULATE(SUM('fCashFlow'[Amount]), 'fCashFlow'[AccountHead] = "freeCashFlow", 'dCalendar'[Year] = LoopYear, REMOVEFILTERS('dAccount'), REMOVEFILTERS('dValuationMetrics'))
			        VAR ForecastNetIncome = CALCULATE(SUM('fIncomeStatementForecast'[Amount]), 'fIncomeStatementForecast'[IsForecast] = 1, 'fIncomeStatementForecast'[AccountHead] = "Net Income", 'dCalendar'[Year] = LoopYear, REMOVEFILTERS('dAccount'), REMOVEFILTERS('dValuationMetrics'))
			        VAR ProjectedFCF = ForecastNetIncome * CashConversionRate
			        RETURN
			            IF(LoopYear <= 2025, ActualFCF, ProjectedFCF)
			    )
			
			VAR CumulativeCapExOutlays = 
			    SUMX(
			        TimelineHorizon,
			        VAR LoopYear = 'dCalendar'[Year]
			        VAR ActualCapEx = CALCULATE(ABS(SUM('fCashFlow'[Amount])), 'fCashFlow'[AccountHead] = "capitalExpenditure", 'dCalendar'[Year] = LoopYear, REMOVEFILTERS('dAccount'), REMOVEFILTERS('dValuationMetrics'))
			        VAR ForecastNetIncome = CALCULATE(SUM('fIncomeStatementForecast'[Amount]), 'fIncomeStatementForecast'[IsForecast] = 1, 'fIncomeStatementForecast'[AccountHead] = "Net Income", 'dCalendar'[Year] = LoopYear, REMOVEFILTERS('dAccount'), REMOVEFILTERS('dValuationMetrics'))
			        VAR ProjectedCapEx = ForecastNetIncome * CapExIntensityRate
			        RETURN
			            IF(LoopYear <= 2025, ActualCapEx, ProjectedCapEx)
			    )
			
			-- 4. Calculate your clean financial return percentage without any double-subtraction bugs
			RETURN 
			    IF(
			        NOT(ISBLANK(CurrentYearRow)) && CumulativeCapExOutlays > 0,
			        DIVIDE(CumulativeCashInflows - CumulativeCapExOutlays, CumulativeCapExOutlays, 0),
			        BLANK()
			    )
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: b8ba704c-a684-43ee-91ff-00dd21aee2f4

	measure Dynamic_Free_Cash_Flow =
			
			VAR CurrentYear = MAX('dCalendar'[Year])
			VAR SelectedScenario = SELECTEDVALUE('dScenario'[ScenarioName], "Forecast")
			VAR ScenarioMultiplier =
			    SWITCH(
			        SelectedScenario,
			        "Optimistic DCF", 1.15,
			        "Pessimistic DCF", 0.85,
			        1.00
			    )
			
			VAR HistNetIncome =
			    CALCULATE(
			        SUM('fIncomeStatementForecast'[Amount]),
			        'fIncomeStatementForecast'[IsForecast] = 0,
			        'fIncomeStatementForecast'[AccountHead] = "Net Income",
			        REMOVEFILTERS()
			    )
			
			VAR HistFCF =
			    CALCULATE(
			        SUM('fCashFlow'[Amount]),
			        'fCashFlow'[AccountHead] = "freeCashFlow",
			        REMOVEFILTERS()
			    )
			
			VAR CashConversionRate =
			    DIVIDE(HistFCF, HistNetIncome, 0)
			
			VAR ActualFCF =
			    CALCULATE(
			        SUM('fCashFlow'[Amount]),
			        'fCashFlow'[AccountHead] = "freeCashFlow",
			        'dCalendar'[Year] = CurrentYear
			    )
			
			VAR ForecastNetIncome =
			    CALCULATE(
			        SUM('fIncomeStatementForecast'[Amount]),
			        'fIncomeStatementForecast'[IsForecast] = 1,
			        'fIncomeStatementForecast'[AccountHead] = "Net Income",
			        'dCalendar'[Year] = CurrentYear,
			        REMOVEFILTERS()
			    )
			
			VAR ForecastFCF =
			    ForecastNetIncome * CashConversionRate * ScenarioMultiplier
			
			RETURN
			    IF(
			        CurrentYear <= 2025,
			        ActualFCF,
			        ForecastFCF
			    )
		formatString: #,0
		lineageTag: b1be117c-2fdd-474a-bf0a-68df111e30c3

	measure Budget_Variance_vs_Actual = ```
			
			VAR CurrentAccountHead = SELECTEDVALUE('dAccount'[AccountHead])
			
			RETURN
			    IF(
			        NOT(CurrentAccountHead IN {"researchAndDevelopmentExpenses", "sellingGeneralAndAdministrativeExpenses", "operatingExpenses"}),
			        BLANK(),
			        
			        VAR ActualValue = 
			            CALCULATE(
			                [Unified_Financial_Metric],
			                TREATAS({"Actual"}, 'dScenario'[ScenarioName])
			            )
			        
			        VAR BudgetValue = 
			            CALCULATE(
			                [Unified_Financial_Metric],
			                TREATAS({"Budget"}, 'dScenario'[ScenarioName])
			            )
			        
			        RETURN BudgetValue - ActualValue
			    )
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 7cd0c65f-8205-4a08-bad3-43414ea82460

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure Dynamic_Annual_CapEx =
			
			VAR Y = MAX('dCalendar'[Year])
			RETURN
			IF(
			    Y <= 2025,
			    CALCULATE(
			        ABS(SUM('fCashFlow'[Amount])),
			        'fCashFlow'[AccountHead] = "capitalExpenditure",
			        'dCalendar'[Year] = Y
			    ),
			    CALCULATE(
			        SUM('fIncomeStatementForecast'[Amount]),
			        'fIncomeStatementForecast'[IsForecast] = 1,
			        'fIncomeStatementForecast'[AccountHead] = "Net Income",
			        'dCalendar'[Year] = Y
			    )
			    *
			    DIVIDE(
			        CALCULATE(
			            ABS(SUM('fCashFlow'[Amount])),
			            'fCashFlow'[AccountHead] = "capitalExpenditure",
			            REMOVEFILTERS()
			        ),
			        CALCULATE(
			            SUM('fIncomeStatementForecast'[Amount]),
			            'fIncomeStatementForecast'[IsForecast] = 0,
			            'fIncomeStatementForecast'[AccountHead] = "Net Income",
			            REMOVEFILTERS()
			        ),
			        0
			    )
			)
		formatString: #,0.00
		lineageTag: d8adc3e1-9099-4b95-9b71-5a1a94d8369a

	measure Dynamic_Payback_Period = ```
			
			-- 1. Dynamically target the specific year's CapEx budget from the matrix row
			VAR CurrentYear = MAX('dCalendar'[Year])
			VAR TargetInvestment = [Dynamic_Annual_CapEx]
			
			-- Only evaluate if there is an active CapEx investment to recover
			RETURN
			IF(
			    TargetInvestment > 0,
			    VAR YearHorizon = 
			        FILTER(
			            ALL('dCalendar'[Year]), 
			            'dCalendar'[Year] >= CurrentYear && 'dCalendar'[Year] <= 2030
			        )
			
			    -- 2. Build a running total of cash generated strictly AFTER the current investment year
			    VAR CumulativeTable = 
			        ADDCOLUMNS(
			            YearHorizon,
			            "CurrentYearFCF", 
			                IF('dCalendar'[Year] <= 2025, [Dynamic_Free_Cash_Flow], [Master_Discounted_FCF]),
			            "ForwardCumulativeFCF",
			                VAR LoopYear = 'dCalendar'[Year]
			                RETURN
			                    SUMX(
			                        FILTER(YearHorizon, 'dCalendar'[Year] <= LoopYear),
			                        IF('dCalendar'[Year] <= 2025, [Dynamic_Free_Cash_Flow], [Master_Discounted_FCF])
			                    )
			        )
			
			    -- 3. Pinpoint the explicit breakeven milestone year
			    VAR BreakEvenYear = 
			        MINX(
			            FILTER(CumulativeTable, [ForwardCumulativeFCF] >= TargetInvestment),
			            'dCalendar'[Year]
			        )
			
			    -- 4. Calculate the precise decimal fraction components
			    VAR PriorYear = BreakEvenYear - 1
			    VAR PriorCumulativeFCF = 
			        COALESCE(
			            MAXX(FILTER(CumulativeTable, 'dCalendar'[Year] = PriorYear), [ForwardCumulativeFCF]),
			            0
			        )
			    VAR TargetYearNetCash = 
			        MAXX(FILTER(CumulativeTable, 'dCalendar'[Year] = BreakEvenYear), [CurrentYearFCF])
			
			    VAR RemainingAmountNeeded = TargetInvestment - PriorCumulativeFCF
			    VAR Fraction = DIVIDE(RemainingAmountNeeded, TargetYearNetCash, 0)
			    VAR WholeYears = BreakEvenYear - CurrentYear
			
			    RETURN
			        IF(
			            ISBLANK(BreakEvenYear),
			            BLANK(), -- Investment does not clear within the 2030 forecast window
			            WholeYears + Fraction
			        ),
			    BLANK()
			)
			
			```
		lineageTag: 2c2e2c3c-0fd2-42e0-a925-9f993c07e270

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Cumulative_Discounted_FCF =
			
			VAR CurrentYear = MAX('dCalendar'[Year])
			VAR YearsToAdd =
			    FILTER(
			        SUMMARIZE(ALL('dCalendar'), 'dCalendar'[Year]),
			        'dCalendar'[Year] >= 2021
			            && 'dCalendar'[Year] <= CurrentYear
			    )
			RETURN
			SUMX(
			    YearsToAdd,
			    VAR Y = 'dCalendar'[Year]
			    VAR ForecastDCF =
			        CALCULATE(
			            [Master_Discounted_FCF],
			            REMOVEFILTERS('dCalendar'),
			            REMOVEFILTERS('fIncomeStatementForecast'[Year]),
			            'dCalendar'[Year] = Y
			        )
			    VAR HistoricalFCF =
			        CALCULATE(
			            SUM('fCashFlow'[Amount]),
			            'fCashFlow'[AccountHead] = "freeCashFlow",
			            REMOVEFILTERS('dCalendar'),
			            'dCalendar'[Year] = Y
			        )
			    RETURN
			        IF(Y <= 2025, HistoricalFCF, ForecastDCF)
			)
		formatString: #,0
		lineageTag: f421fdcf-d70f-4e5e-b2ae-9c2b75d39b54

		annotation PBI_FormatHint = {"isDecimal":true}

	measure Cumulative_CapEx =
			
			VAR CurrentYear = MAX('dCalendar'[Year])
			
			VAR YearsToAdd =
			    FILTER(
			        SUMMARIZE(
			            ALL('dCalendar'),
			            'dCalendar'[Year]
			        ),
			        'dCalendar'[Year] >= 2021
			            && 'dCalendar'[Year] <= CurrentYear
			    )
			
			VAR GlobalHistNI =
			    CALCULATE(
			        SUM('fIncomeStatementForecast'[Amount]),
			        'fIncomeStatementForecast'[IsForecast] = 0,
			        'fIncomeStatementForecast'[AccountHead] = "Net Income",
			        REMOVEFILTERS()
			    )
			
			VAR GlobalHistCapEx =
			    CALCULATE(
			        ABS(SUM('fCashFlow'[Amount])),
			        'fCashFlow'[AccountHead] = "capitalExpenditure",
			        REMOVEFILTERS()
			    )
			
			VAR CapExFactor = DIVIDE(GlobalHistCapEx, GlobalHistNI, 0)
			
			RETURN
			SUMX(
			    YearsToAdd,
			    VAR Y = 'dCalendar'[Year]
			    VAR ActualCapEx =
			        CALCULATE(
			            ABS(SUM('fCashFlow'[Amount])),
			            REMOVEFILTERS('dCalendar'),
			            'dCalendar'[Year] = Y,
			            'fCashFlow'[AccountHead] = "capitalExpenditure"
			        )
			    VAR ForecastCapEx =
			        CALCULATE(
			            SUM('fIncomeStatementForecast'[Amount]),
			            REMOVEFILTERS('dCalendar'),
			            REMOVEFILTERS('fIncomeStatementForecast'[Year]),
			            'dCalendar'[Year] = Y,
			            'fIncomeStatementForecast'[IsForecast] = 1,
			            'fIncomeStatementForecast'[AccountHead] = "Net Income"
			        ) * CapExFactor
			    RETURN
			        IF(Y <= 2025, ActualCapEx, ForecastCapEx)
			)
		formatString: #,0
		lineageTag: 14b85e0f-1894-475e-825f-57382ea936a3

	measure Net_Cumulative_Balance =
			
			[Cumulative_Discounted_FCF] - [Cumulative_CapEx]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 0163b13a-dad3-4161-be7f-a33e3ba6ace4

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure Dynamic_Payback_Year_KPI = ```
			
			-- 1. Identify the specific matrix row year and its CapEx hurdle
			VAR CurrentYear = MAX('dCalendar'[Year])
			VAR TargetInvestment = [Dynamic_Annual_CapEx]
			
			RETURN
			IF(
			    TargetInvestment > 0,
			    -- 2. Build a timeline that only looks FORWARD from the current row year
			    VAR ForwardHorizon = 
			        FILTER(
			            ALL('dCalendar'[Year]), 
			            'dCalendar'[Year] >= CurrentYear && 'dCalendar'[Year] <= 2030
			        )
			
			    -- 3. Calculate running cash flows starting strictly from the investment year
			    VAR BreakEvenYear =
			        MINX(
			            FILTER(
			                ForwardHorizon,
			                VAR LoopYear = 'dCalendar'[Year]
			                VAR ForwardCumulativeFCF =
			                    SUMX(
			                        FILTER(ForwardHorizon, 'dCalendar'[Year] <= LoopYear),
			                        IF('dCalendar'[Year] <= 2025, [Dynamic_Free_Cash_Flow], [Master_Discounted_FCF])
			                    )
			                RETURN
			                    ForwardCumulativeFCF >= TargetInvestment
			            ),
			            'dCalendar'[Year]
			        )
			
			    RETURN
			        BreakEvenYear,
			    BLANK()
			)
			
			```
		formatString: 0
		lineageTag: c6359f9a-6bd7-43b5-897a-224fcd57714c

	measure Project_ROI_Overall = ```
			
			VAR HorizonYears = 
			    CALCULATETABLE(
			        VALUES('dCalendar'[Year]),
			        'dCalendar'[Year] >= 2021 && 'dCalendar'[Year] <= 2030,
			        REMOVEFILTERS()
			    )
			
			-- 1. Combine historical actual cash with future discounted cash flows
			VAR TotalMixedInflows = 
			    SUMX(
			        HorizonYears,
			        VAR LoopYear = 'dCalendar'[Year]
			        RETURN
			            IF(
			                LoopYear <= 2025,
			                -- 2021-2025: Raw Historical Free Cash Flow
			                CALCULATE(
			                    [Dynamic_Free_Cash_Flow],
			                    'dCalendar'[Year] = LoopYear,
			                    REMOVEFILTERS('dAccount'), REMOVEFILTERS('dValuationMetrics'), REMOVEFILTERS('dScenario'), REMOVEFILTERS('dCalendar')
			                ),
			                -- 2026-2030: Future Discounted Present Value Flows
			                CALCULATE(
			                    [Master_Discounted_FCF],
			                    'dCalendar'[Year] = LoopYear,
			                    REMOVEFILTERS('dAccount'), REMOVEFILTERS('dValuationMetrics'), REMOVEFILTERS('dScenario'), REMOVEFILTERS('dCalendar')
			                )
			            )
			    )
			
			-- 2. Sum up your raw annual CapEx requirements across the entire 10-year window
			VAR TotalOutflows = 
			    SUMX(
			        HorizonYears,
			        VAR LoopYear = 'dCalendar'[Year]
			        RETURN
			            CALCULATE(
			                [Dynamic_Annual_CapEx],
			                'dCalendar'[Year] = LoopYear,
			                REMOVEFILTERS('dAccount'), REMOVEFILTERS('dValuationMetrics'), REMOVEFILTERS('dScenario'), REMOVEFILTERS('dCalendar')
			            )
			    )
			
			-- 3. Execute the Discounted ROI formula
			RETURN 
			    IF(
			        TotalOutflows > 0,
			        DIVIDE(TotalMixedInflows - TotalOutflows, TotalOutflows, 0),
			        BLANK()
			    )
			
			```
		formatString: #,0.00%;-#,0.00%;#,0.00%
		lineageTag: b8b1cced-f500-4c8f-b7ff-a0de9cbadeec

	measure Dynamic_Payback_Period_Cumulative = ```
			
			VAR CurrentYearRow = COALESCE(SELECTEDVALUE('dCalendar'[Year]), SELECTEDVALUE('fIncomeStatementForecast'[Year]))
			
			RETURN
			IF(
			    NOT(ISBLANK(CurrentYearRow)),
			    -- 1. Grab the cumulative CapEx target up to the active visual row year
			    VAR CumulativeTargetInvestment = [Cumulative_CapEx]
			    
			    -- 2. Generate a clean list of base timeline years
			    VAR YearHorizon = 
			        FILTER(
			            ALL('dCalendar'[Year]), 
			            'dCalendar'[Year] >= 2021 && 'dCalendar'[Year] <= 2030
			        )
			        
			    -- 3. Calculate the true, isolated sequential accumulation of FCF
			    VAR CumulativeTable = 
			        ADDCOLUMNS(
			            YearHorizon,
			            "NominalYearFCF", 
			                VAR Y = 'dCalendar'[Year]
			                RETURN CALCULATE([Dynamic_Free_Cash_Flow], 'dCalendar'[Year] = Y, REMOVEFILTERS('dCalendar')),
			            "CumulativeNominalFCF",
			                VAR LoopYear = 'dCalendar'[Year]
			                RETURN
			                    CALCULATE(
			                        SUMX(
			                            FILTER(YearHorizon, 'dCalendar'[Year] <= LoopYear),
			                            VAR InnerYear = 'dCalendar'[Year]
			                            RETURN CALCULATE([Dynamic_Free_Cash_Flow], 'dCalendar'[Year] = InnerYear, REMOVEFILTERS('dCalendar'))
			                        ),
			                        REMOVEFILTERS('dCalendar')
			                    )
			        )
			
			    -- 4. Locate the exact calendar milestone where cash overtakes the accumulated CapEx
			    VAR BreakEvenYear = 
			        MINX(
			            FILTER(CumulativeTable, [CumulativeNominalFCF] >= CumulativeTargetInvestment),
			            'dCalendar'[Year]
			        )
			
			    -- 5. Build precise mathematical decimal offsets relative to the 2021 baseline anchor
			    VAR PriorYear = BreakEvenYear - 1
			    VAR PriorCumulativeFCF = 
			        COALESCE(
			            MAXX(FILTER(CumulativeTable, 'dCalendar'[Year] = PriorYear), [CumulativeNominalFCF]),
			            0
			        )
			    VAR TargetYearNetCash = 
			        MAXX(FILTER(CumulativeTable, 'dCalendar'[Year] = BreakEvenYear), [NominalYearFCF])
			
			    VAR RemainingAmountNeeded = CumulativeTargetInvestment - PriorCumulativeFCF
			    VAR Fraction = DIVIDE(RemainingAmountNeeded, TargetYearNetCash, 0)
			    VAR WholeYears = BreakEvenYear - 2021
			
			    RETURN
			        IF(
			            ISBLANK(BreakEvenYear),
			            BLANK(),
			            WholeYears + Fraction
			        ),
			    BLANK()
			)
			
			```
		formatString: #,0.00
		lineageTag: ce502f78-6918-44ea-94af-b579b0787213

	measure Dynamic_Payback_Period_Annual = ```
			
			VAR CurrentYear = 
			    COALESCE(
			        SELECTEDVALUE('dCalendar'[Year]), 
			        SELECTEDVALUE('fIncomeStatementForecast'[Year])
			    )
			
			VAR AnnualInvestment = [Dynamic_Annual_CapEx]
			VAR AnnualFCF = [Dynamic_Free_Cash_Flow]
			
			RETURN
			IF(
			    NOT(ISBLANK(CurrentYear)) && AnnualFCF > 0 && AnnualInvestment > 0,
			    -- Simple single-year operational recovery rate
			    DIVIDE(AnnualInvestment, AnnualFCF, 0),
			    BLANK()
			)
			
			```
		lineageTag: 47422b1f-9cc5-49b5-a5fb-e21e192bd6c2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Budget_Discount_Variance = ```
			
			VAR CurrentYear = MAX('dCalendar'[Year])
			VAR YearIndex = CurrentYear - 2025
			
			-- 1. Pull the nominal budget amount from your fInternalBudget fact table
			VAR NominalBudget = SUM('fInternalBudgets'[BudgetAmount])
			
			-- 2. Discount the budget using your macro WACC Engine
			VAR WACC = [WACC_Engine]
			VAR DiscountedBudget = 
			    IF(YearIndex > 0 && NominalBudget > 0, DIVIDE(NominalBudget, POWER(1 + WACC, YearIndex), 0), NominalBudget)
			
			-- 3. Discount the budget using the fixed 9% baseline anchor
			VAR BaselineWACC = 0.09
			VAR BaselineDiscountedBudget = 
			    IF(YearIndex > 0 && NominalBudget > 0, DIVIDE(NominalBudget, POWER(1 + BaselineWACC, YearIndex), 0), NominalBudget)
			
			RETURN
			    IF(
			        NOT(ISBLANK(DiscountedBudget)),
			        DiscountedBudget - BaselineDiscountedBudget,
			        BLANK()
			    )
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: bd1a9d57-51e0-4d3e-91ab-ffc6b07e396a

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

