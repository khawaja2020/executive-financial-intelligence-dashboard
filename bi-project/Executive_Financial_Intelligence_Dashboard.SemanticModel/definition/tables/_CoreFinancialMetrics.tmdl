	measure Metric_BookValuePerShare = ```
			
			
			-- 1. Calculate Total Equity by filtering the unpivoted table
			VAR TotalEquity = 
			    CALCULATE(
			        SUM('fBalanceSheet'[Amount]), 
			        'dAccount'[AccountHead] = "totalEquity"
			    )
			
			-- 2. Calculate Shares Outstanding using SharesOutstanding table
			VAR SharesOutstanding = 
			    MAX('ShareOutstanding'[NumberOfShares])
			
			-- 3. Safely divide to avoid divide-by-zero errors
			RETURN
			    DIVIDE(TotalEquity, SharesOutstanding, 0)
			
			```
